#!/usr/bin/env bash
set -euo pipefail

cd ~/mew

mkdir -p .github/workflows
mkdir -p crates/mew-ui/tests
mkdir -p crates/mew-common/tests
mkdir -p crates/mew-cli/tests

python3 - <<'PY'
from pathlib import Path

p = Path("Cargo.toml")
s = p.read_text()

adds = {
    'terminal_size = "0.3"': 'terminal_size = "0.3"',
    'textwrap = "0.16"': 'textwrap = "0.16"',
    'unicode-width = "0.1"': 'unicode-width = "0.1"',
    'strip-ansi-escapes = "0.2"': 'strip-ansi-escapes = "0.2"',
}

for line in adds:
    if line not in s:
        s += "\n" + line

p.write_text(s)
PY

